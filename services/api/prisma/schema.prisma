generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id                String      @id @default(cuid())
  phone             String      @unique
  name              String
  email             String?
  city              String
  pincode           String
  platform          String
  upiHandle         String
  aadhaarLast4      String
  deviceFingerprint String?
  tenureWeeks       Int         @default(0)
  baselineIncomePaise Int
  status            String      @default("active")
  createdAt         DateTime    @default(now())

  policies   Policy[]
  payouts    Payout[]
  fraudFlags FraudFlag[]
}

model Policy {
  id                String    @id @default(cuid())
  workerId          String
  worker            Worker    @relation(fields: [workerId], references: [id])
  weekStart         DateTime
  weekEnd           DateTime
  premiumAmountPaise Int
  riskScore         Float
  status            String    @default("active")
  premiumPaidAt     DateTime?
  createdAt         DateTime  @default(now())

  payouts Payout[]
}

model Payout {
  id               String   @id @default(cuid())
  workerId         String
  worker           Worker   @relation(fields: [workerId], references: [id])
  policyId         String
  policy           Policy   @relation(fields: [policyId], references: [id])
  triggerType      String
  triggerValue     Float
  payoutAmountPaise Int
  fraudScore       Float
  fraudComponents  Json
  status           String
  razorpayId       String?
  creditedAt       DateTime?
  createdAt        DateTime @default(now())
}

model SensorReading {
  id             String   @id @default(cuid())
  city           String
  pincode        String?
  rainfallMmHr   Float
  heatIndexC     Float
  aqiScore       Int
  cancelRatePct  Float
  platformStatus String
  orderDensity   Float
  source         String
  recordedAt     DateTime @default(now())

  @@index([city, recordedAt])
}

model FraudFlag {
  id           String   @id @default(cuid())
  workerId     String
  worker       Worker   @relation(fields: [workerId], references: [id])
  payoutId     String?
  flagType     String
  scoreB       Float
  scoreG       Float
  scoreL       Float
  scoreTotal   Float
  reviewStatus String   @default("pending")
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

